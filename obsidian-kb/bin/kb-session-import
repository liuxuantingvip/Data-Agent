#!/bin/zsh

set -euo pipefail

ROOT="/Users/sensen/Desktop/codex/obsidian-kb"

if [[ $# -lt 2 ]]; then
  echo "Usage: kb-session-import <tool> <transcript-file> [project] [title]" >&2
  exit 1
fi

tool="$1"
file="$2"
project="${3:-shared}"
title="${4:-}"

if [[ -n "$title" ]]; then
  "$ROOT/kb-ai" session import --tool "$tool" --from "$file" --project "$project" --title "$title"
else
  "$ROOT/kb-ai" session import --tool "$tool" --from "$file" --project "$project"
fi
